# API Keys for the Research Orchestrator MCP servers.
# All are optional — the system falls back to Copilot's built-in web_fetch /
# web_search when an MCP server isn't loaded. Add only the ones you want.
#
# Usage:
#   cp .env.example .env  &&  edit  &&  source .env

# ── Web search ──────────────────────────────────────────────────────────
# Tavily — Primary web search + extraction. Free: 1000 searches/mo.
# https://tavily.com
export TAVILY_API_KEY=""

# Brave Search — Cross-checking surface (different result mix). Free: 2000/mo.
# https://brave.com/search/api
export BRAVE_API_KEY=""

# ── Academic ────────────────────────────────────────────────────────────
# Semantic Scholar — Citation graph traversal. Free, but a key raises rate limits.
# https://www.semanticscholar.org/product/api
export SEMANTIC_SCHOLAR_API_KEY=""

# ArXiv MCP — no key required.

# ── Deep fetch ──────────────────────────────────────────────────────────
# Firecrawl — JS-rendered scraping. Free: 500 pages/mo.
# https://firecrawl.dev
export FIRECRAWL_API_KEY=""

# ── Repo / metrics ──────────────────────────────────────────────────────
# GitHub — for trend_quantifier (stars history, contributors). Optional.
# https://github.com/settings/tokens (read-only `public_repo` scope is enough)
export GITHUB_PERSONAL_ACCESS_TOKEN=""

# ── Optional cross-check ────────────────────────────────────────────────
# Perplexity — AI Q&A as an extra falsification surface.
# https://www.perplexity.ai/settings/api
export PERPLEXITY_API_KEY=""
